Bootstrap: docker
From: registry.access.redhat.com/ubi8/ubi:latest

%help
    This container builds and runs an OpenMP-enabled C application on RHEL ubi8.

%setup
    # This runs on the host during build. 
    # Ensure your source code (e.g., hello_openmp.c) is in the same directory.
    mkdir -p ${APPTAINER_ROOTFS}/mnt/host_cache

%files
    # Copy your source code into the container
    /usr/bin/csh /usr/bin/csh
    /usr/local/lib/sbcl /usr/local/lib/
    /usr/local/bin/sbcl /usr/local/bin/
    /scratch1/skoranne/OSS_EDA_TOOLS/nesl/bin/ /scratch1/skoranne/OSS_EDA_TOOLS/nesl/
    /scratch1/skoranne/OSS_EDA_TOOLS/nesl/nesl.image /usr/local/lib/sbcl/nesl.image
%post
    # Update and install GCC and OpenMP libraries
    # dnf -y install https://fedoraproject.org
    sed -i 's/keepcache=0/keepcache=1/g' /etc/yum.conf
    sed -i 's|cachedir=.*|cachedir=/mnt/host_cache|g' /etc/yum.conf
 
    # Clean up yum cache to keep the image slim
    yum clean all
    # dnf clean all
%environment
    # Set default OpenMP environment variables
    export LC_ALL=C
%runscript
    # This is what happens when you call 'apptainer run'
    exec /usr/local/bin/sbcl --core /usr/local/lib/sbcl/nesl.image "$@"

%labels
    Author SandeepKoranne
    Version 1.0
    Description SBCL on RHEL ubi8

